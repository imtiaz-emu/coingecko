<% content_for :title, "shrtn.io — Shorten a URL" %>

<div class="card shadow-sm">
  <div class="card-body p-4">
    <h1 class="h4 mb-4">Shorten a URL</h1>

    <% if @error_key %>
      <div class="alert alert-danger">
        <%= t("errors.short_url.#{@error_key}", default: t("errors.short_url.generic")) %>
      </div>
    <% end %>

    <%= form_with url: create_short_url_path, method: :post, data: { turbo: false } do |f| %>
      <div class="mb-3">
        <%= f.label :target_url, "Long URL", class: "form-label fw-semibold" %>
        <%= f.url_field :target_url,
              name: "short_url[target_url]",
              placeholder: "https://example.com/very/long/path",
              class: "form-control form-control-lg",
              required: true,
              autofocus: true %>
      </div>

      <div class="mb-4">
        <%= f.label :custom_slug, "Custom slug (optional)", class: "form-label fw-semibold" %>
        <div class="input-group">
          <span class="input-group-text text-muted">shrtn.io/</span>
          <%= f.text_field :custom_slug,
                name: "short_url[custom_slug]",
                placeholder: "my-brand",
                class: "form-control",
                pattern: "[a-zA-Z0-9_\\-]{1,15}",
                maxlength: 15 %>
        </div>
        <div class="form-text">Up to 15 characters — letters, numbers, hyphens, underscores.</div>
      </div>

      <%= f.submit "Shorten URL", class: "btn btn-primary btn-lg w-100" %>
    <% end %>
  </div>
</div>
